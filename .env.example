# =============================================================================
# StrideMarket — Environment variables (copy to .env at repo root)
# =============================================================================
# Each app also has its own .env.example. Root vars are loaded by Docker Compose.

# --- Database ---
DATABASE_URL="postgresql://stride:stride_dev@localhost:5432/stride_market?schema=public"

# --- Redis (job queue + cache) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=4000
API_URL="http://localhost:4000"
NODE_ENV="development"

# iron-session: generate with `openssl rand -base64 32`
SESSION_SECRET="replace-with-32-plus-char-secret"

# JWT (optional complement to session for mobile/API clients)
JWT_ACCESS_SECRET="replace-access-secret"
JWT_REFRESH_SECRET="replace-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# CORS — Next.js dev server
WEB_ORIGIN="http://localhost:3000"

# --- OpenAI (worker + API AI routes) ---
OPENAI_API_KEY="sk-..."

# --- Email (worker processes outbound mail) ---
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="StrideMarket <noreply@stridemarket.local>"

# --- File storage (local dev; swap for S3 in production) ---
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./uploads"
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Worker ---
WORKER_PORT=4001

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:4000/graphql"
NEXT_PUBLIC_TRPC_URL="http://localhost:4000/trpc"
